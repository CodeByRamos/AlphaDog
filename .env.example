# Modelo de variáveis. NUNCA coloque credencial real aqui — este arquivo é
# versionado. Copie para .env.local (gitignored) e preencha lá.

# URL pública do site (SEO, canonical, OpenGraph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Supabase / Postgres
# DATABASE_URL: pooler (porta 6543) — usado pela aplicação em runtime.
# DIRECT_URL:   conexão direta (porta 5432) — usada pelas migrations.
# Sem estas variáveis o projeto roda com os stores em memória.
DATABASE_URL=""
DIRECT_URL=""

# Auth.js — gere com: npx auth secret
AUTH_SECRET=""

# Stripe (modo teste)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
