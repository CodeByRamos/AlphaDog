// AlphaDog — modelo de dados.
//
// Agrupado por domínio: identidade, cão, funil, oferta/cobrança, programa e
// conteúdo. Dinheiro sempre em centavos (Int) — nunca Float.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// As URLs de conexão ficam em prisma.config.ts — no Prisma 7 elas saíram do
// schema.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------- identidade

enum Role {
  USER
  EXPERT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  dogs          Dog[]
  subscriptions Subscription[]
  quizSessions  QuizSession[]
  lessonProgress LessonProgress[]
  streak        Streak?
  questions     ExpertQuestion[]

  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------- cão

enum AgeGroup {
  PUPPY
  ADOLESCENT
  ADULT
  SENIOR
}

enum Gender {
  MALE
  FEMALE
}

/// Alimenta o dropdown do funil e as páginas de wiki com SEO.
model Breed {
  slug      String  @id
  name      String
  size      String?
  energy    String?
  traits    String[]
  summary   String?
  createdAt DateTime @default(now())

  dogs Dog[]
}

model Dog {
  id        String    @id @default(cuid())
  userId    String
  name      String
  breedSlug String?
  ageGroup  AgeGroup
  gender    Gender?
  birthDate DateTime?
  photoUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  breed    Breed?    @relation(fields: [breedSlug], references: [slug])
  programs Program[]

  @@index([userId])
}

// --------------------------------------------------------------------- funil

enum QuizStatus {
  STARTED
  COMPLETED
  ABANDONED
}

/// Permite versionar o funil e rodar variantes de A/B sem migração.
model QuizFunnel {
  id        String   @id @default(cuid())
  slug      String   @unique
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions QuizSession[]
}

model QuizSession {
  id          String     @id @default(cuid())
  funnelSlug  String
  userId      String?
  status      QuizStatus @default(STARTED)
  utmSource   String?
  /// Respostas desnormalizadas para leitura rápida no paywall.
  answers     Json       @default("{}")
  startedAt   DateTime   @default(now())
  completedAt DateTime?

  funnel  QuizFunnel   @relation(fields: [funnelSlug], references: [slug])
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  answerRows QuizAnswer[]
  offer   Offer?
  events  FunnelEvent[]

  @@index([userId])
  @@index([status, startedAt])
}

/// Uma linha por resposta — é o que permite medir drop-off por passo.
model QuizAnswer {
  id        String   @id @default(cuid())
  sessionId String
  stepKey   String
  value     Json
  createdAt DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepKey])
  @@index([stepKey])
}

model FunnelEvent {
  id        String   @id @default(cuid())
  sessionId String
  stepKey   String
  event     String
  meta      Json?
  createdAt DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([stepKey, event])
}

// ---------------------------------------------------------- oferta e cobrança

enum OfferSource {
  SCRATCH_CARD
  FORTUNE_WHEEL
}

/// Desconto gamificado. O percentual e o prazo vivem aqui, no servidor —
/// nunca no cliente.
model Offer {
  id         String      @id @default(cuid())
  sessionId  String      @unique
  source     OfferSource
  percentOff Int
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Price {
  id               String  @id @default(cuid())
  stripePriceId    String  @unique
  planId           String
  interval         String
  intervalCount    Int
  /// Centavos.
  amountCents      Int
  /// Valor da renovação, quando o primeiro ciclo é promocional.
  renewAmountCents Int?
  currency         String  @default("BRL")
  isActive         Boolean @default(true)

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  EXPIRED
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  priceId              String?
  stripeCustomerId     String
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  price    Price?    @relation(fields: [priceId], references: [id])
  invoices Invoice[]
  refunds  RefundRequest[]

  @@index([userId])
  @@index([status])
}

model Invoice {
  id              String   @id @default(cuid())
  subscriptionId  String
  stripeInvoiceId String   @unique
  amountPaidCents Int
  currency        String   @default("BRL")
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

enum RefundStatus {
  REQUESTED
  APPROVED
  DENIED
  REFUNDED
}

/// Garantia de 30 dias — o pedido vira registro auditável, não e-mail solto.
model RefundRequest {
  id             String       @id @default(cuid())
  subscriptionId String
  reason         String
  status         RefundStatus @default(REQUESTED)
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ------------------------------------------------------------------ programa

model Program {
  id            String   @id @default(cuid())
  dogId         String
  level         String
  focusAreas    String[]
  durationWeeks Int      @default(4)
  minutesPerDay Int      @default(10)
  generatedAt   DateTime @default(now())

  dog  Dog          @relation(fields: [dogId], references: [id], onDelete: Cascade)
  days ProgramDay[]

  @@index([dogId])
}

model ProgramDay {
  id        String   @id @default(cuid())
  programId String
  dayIndex  Int
  lessonIds String[]

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, dayIndex])
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  level       String?
  order       Int
  createdAt   DateTime @default(now())

  lessons Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  slug        String   @unique
  title       String
  body        String?
  videoUrl    String?
  durationSec Int?
  order       Int
  createdAt   DateTime @default(now())

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LessonProgress {
  id          String         @id @default(cuid())
  userId      String
  lessonId    String
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?
  updatedAt   DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, status])
}

model Streak {
  userId         String   @id
  current        Int      @default(0)
  longest        Int      @default(0)
  lastActiveDate DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------------------ conteúdo

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  body        String
  coverUrl    String?
  tags        String[]
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
}

model Review {
  id          String   @id @default(cuid())
  source      String
  authorName  String
  dogName     String?
  rating      Int
  body        String
  isApproved  Boolean  @default(false)
  publishedAt DateTime @default(now())

  @@index([isApproved, publishedAt])
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

model ExpertQuestion {
  id        String         @id @default(cuid())
  userId    String
  body      String
  videoUrl  String?
  status    QuestionStatus @default(OPEN)
  createdAt DateTime       @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer ExpertAnswer?

  @@index([status, createdAt])
}

model ExpertAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  expertName String
  body       String
  createdAt  DateTime @default(now())

  question ExpertQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
