{
  "name": "alphadog",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,css,md}\" --ignore-path .gitignore",
    "check:links": "node scripts/check-links.mjs",
    "shot": "node scripts/shot.mjs",
    "baseline": "node scripts/baseline.mjs",
    "brand": "pnpm --filter @alphadog/website brand"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "playwright": "^1.49.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
