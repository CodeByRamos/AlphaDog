# Padrões sem barra inicial casam em qualquer nível — necessário no monorepo,
# porque .next e node_modules agora vivem dentro de apps/*.

# dependências
node_modules/
.pnp
.pnp.*

# testes
coverage/

# next.js
.next/
out/
build/

# turborepo
.turbo/

# expo: cache local do dev server, nunca versionar
.expo/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env: nunca versionar credencial. O .env.example é o modelo e fica vazio.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# client gerado pelo prisma.
# Precisa do `**/`: padrão com barra no meio ancora na raiz do repo, então
# `src/generated/` não casaria em apps/website/src/generated/.
**/src/generated/

# artefatos locais de verificação
/screenshots
/.baseline

# python (services/ai)
.venv/
__pycache__/
*.egg-info/
.pytest_cache/

# dataset: pesado e sob licença própria — nunca versionar.
# Usa data/* e não data/ porque git não re-inclui arquivo se o diretório-pai
# inteiro está excluído — o `!` abaixo só funciona ignorando o conteúdo, não a pasta.
services/ai/data/*
services/ai/runs/

# rotulos de postura: pequenos e trabalho manual, versionar apesar de data/ ser ignorado
!services/ai/data/posture_labels.json
